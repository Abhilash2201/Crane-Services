generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String            @unique
  phone           String?
  passwordHash    String            @map("password_hash")
  role            Role
  isActive        Boolean           @default(true) @map("is_active")
  emailVerifiedAt DateTime?         @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)
  requests        Request[]         @relation("customer_requests")
  ownedRequests   Request[]         @relation("owner_requests")
  refreshTokens   RefreshToken[]
  otpCodes        OtpVerification[]
  customerPays    Payment[]         @relation("customer_payments")
  ownerPays       Payment[]         @relation("owner_payments")
  driverJobs      Job[]             @relation("driver_jobs")
  ownerJobs       Job[]             @relation("owner_jobs")
  trackingEvents  TrackingEvent[]

  @@map("users")
}

model Request {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId           String    @map("customer_id") @db.Uuid
  ownerId              String?   @map("owner_id") @db.Uuid
  pickupAddress        String    @map("pickup_address")
  dropAddress          String?   @map("drop_address")
  requiredCapacityTons Decimal?  @map("required_capacity_tons") @db.Decimal(10, 2)
  scheduledAt          DateTime? @map("scheduled_at") @db.Timestamptz(6)
  status               String    @default("pending")
  notes                String?
  priceQuote           Decimal?  @map("price_quote") @db.Decimal(12, 2)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  customer             User      @relation("customer_requests", fields: [customerId], references: [id], onDelete: Cascade)
  owner                User?     @relation("owner_requests", fields: [ownerId], references: [id], onDelete: SetNull)
  job                  Job?
  payment              Payment?

  @@map("requests")
}

model Job {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId         String         @unique @map("request_id") @db.Uuid
  ownerId           String         @map("owner_id") @db.Uuid
  driverId          String?        @map("driver_id") @db.Uuid
  craneRegistration String?        @map("crane_registration")
  startedAt         DateTime?      @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?      @map("completed_at") @db.Timestamptz(6)
  status            String         @default("assigned")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  request           Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  owner             User           @relation("owner_jobs", fields: [ownerId], references: [id], onDelete: Cascade)
  driver            User?          @relation("driver_jobs", fields: [driverId], references: [id], onDelete: SetNull)
  trackingEvents    TrackingEvent[]

  @@map("jobs")
}

model TrackingEvent {
  id         BigInt    @id @default(autoincrement())
  jobId      String    @map("job_id") @db.Uuid
  driverId   String    @map("driver_id") @db.Uuid
  latitude   Float
  longitude  Float
  speedKmph  Decimal?  @map("speed_kmph") @db.Decimal(6, 2)
  heading    Decimal?  @db.Decimal(6, 2)
  capturedAt DateTime  @default(now()) @map("captured_at") @db.Timestamptz(6)
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  driver     User      @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("tracking_events")
}

model Payment {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId               String    @unique @map("request_id") @db.Uuid
  customerId              String    @map("customer_id") @db.Uuid
  ownerId                 String    @map("owner_id") @db.Uuid
  amount                  Decimal   @db.Decimal(12, 2)
  currency                String    @default("INR")
  status                  String    @default("pending")
  provider                String    @default("manual")
  providerPaymentIntentId String?   @map("provider_payment_intent_id")
  idempotencyKey          String?   @unique @map("idempotency_key")
  paidAt                  DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  request                 Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  customer                User      @relation("customer_payments", fields: [customerId], references: [id], onDelete: Cascade)
  owner                   User      @relation("owner_payments", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model RefreshToken {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  tokenHash        String        @unique @map("token_hash")
  userAgent        String?       @map("user_agent")
  ipAddress        String?       @map("ip_address")
  expiresAt        DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?     @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?      @map("replaced_by_token_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OtpVerification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  targetEmail String    @map("target_email")
  purpose     OtpPurpose
  codeHash    String    @map("code_hash")
  attempts    Int       @default(0)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model PaymentWebhookEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider    String
  eventId     String    @unique @map("event_id")
  eventType   String    @map("event_type")
  payload     Json
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("payment_webhook_events")
}

enum Role {
  admin
  customer
  owner
  driver
}

enum OtpPurpose {
  email_verification
  password_reset
}
